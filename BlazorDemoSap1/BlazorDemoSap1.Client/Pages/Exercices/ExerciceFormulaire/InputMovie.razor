@using BlazorDemoSap1.Client.Models


<EditForm Model="@NewMovie" OnValidSubmit="AddMovieInput" class="text-center w-75 card mx-auto">
    <DataAnnotationsValidator/>
    <ValidationSummary/>

    <div>
        <label>Titre</label>
        <br />
        <input class="form-control w-50 mx-auto" type="text" @bind-value="@NewMovie.Titre" />
        <ValidationMessage For="@(() => NewMovie.Titre)"/>
    </div>

    <div>
        <label>Description</label>
        <br />
        <input class="form-control w-50 mx-auto" type="text" @bind-value="@NewMovie.Description" />
        <ValidationMessage For="@(() => NewMovie.Description)"/>
    </div>

    <div>
        <label>Année de production</label>
        <br />
        <input class="form-control w-50 mx-auto" type="number" @bind-value="@NewMovie.AnneeDeProd" />
        <ValidationMessage For="@(() => NewMovie.AnneeDeProd)" />
    </div>

    <div>
        <label>Réalisateur</label>
        <br />
        <input class="form-control w-50 mx-auto" type="text" @bind-value="@NewMovie.Realisateur" />
        <ValidationMessage For="@(() => NewMovie.Realisateur)" />
    </div>

    <button class="btn btn-outline-success w-25 mx-auto my-3" type="submit">Ajouter</button>
</EditForm>



@code {

    public AddMovie NewMovie { get; set; } = new AddMovie();

    [Parameter]
    public EventCallback<AddMovie> SubmitAction { get; set; }


    public void AddMovieInput()
    {
        SubmitAction.InvokeAsync(NewMovie);
    }

}

