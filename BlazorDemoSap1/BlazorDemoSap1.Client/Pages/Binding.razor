@page "/binding"
@using BlazorDemoSap1.Client.Components
@using BlazorDemoSap1.Client.Models

<h1>Binding</h1>

<div class="card w-75 m-auto shadow mt-3">
    <h2>Binding one way</h2>
    <p>Nom du produit : @product?.Name</p>
</div>

<div class="card w-75 m-auto shadow mt-3">
    <h2>Binding one way</h2>

    <div>
        <input type="text" @bind="messageTwoWay" />
        <p>Message recupéré : @messageAfterInput</p>
        <button @onclick="GetMessage">getMessage</button>
    </div>


    <div class="card w-75 m-auto shadow mt-3">
        <p>message : @message1</p>

        <select @onchange="(e) => GetMessage(e.Value.ToString())">
            @foreach(string s in valueSelect)
            {
                <option>@s</option>
            }
        </select>
    </div>

    <div class="card w-75 m-auto shadow mt-3">
        <h4>Login</h4>
        <input type="type" @bind="Email" />
        <input type="password" @bind="Password"/>
        <button @onclick="Login">Login</button>

        <p>Valeur du login : @ResultLogin</p>
    </div>

</div>

<div class="card w-75 m-auto shadow mt-3">
    <h2>Binding sur une liste </h2>

    @if(products.Count() > 0)
    {

        @foreach(Product p in products)
        {
            <ProductComponent product="p"/>
    
        }
    
    }else
    {
        <p>Aucun produit disponible . . .</p>
    }
</div>

<div class="card w-75 m-auto shadow mt-3">
            <input type="text" @onchange="(e) => Filter(e.Value.ToString())" />

            @if(resultFilter.Count() > 0)
            {

                @foreach(string s in resultFilter)
                {
                    <p>@s</p>
                }
            }
            else
            {
                <p>Aucun résultat trouvé . . .</p>
            }
        </div>


        <div>
            <h2>Communication parent enfant</h2>

            <input type="text" @bind="valueParent"/>

            <Enfant valueFromParent="@valueParent" SendToParent="UpdateValueParent"/>

            <p>value from child : @valueFromChild</p>

        </div>