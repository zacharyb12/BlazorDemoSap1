@page "/games-list"
@using BlazorDemoSap1.Models
@using BlazorDemoSap1.Repository


<h3>GamesList</h3>

<button @onclick="NavigateToAdd">Ajouter un Jeux</button>

<NavLink href="/add-game">Ajouter un Jeux</NavLink>

@if(GameList.Count() == 0)
{
    <p>Aucun Jeux à afficher</p>

}else
{
    @foreach(Game g in GameList)
    {
        <h3>@g.Name</h3>
        <p>@g.Price</p>
        <p>@g.Description</p>
        <button @onclick="() => NavigateToUpdate(g.Id)">Update</button>

    }
}


@code {
    // Injection du service pour utiliser les methodes implémentées
    [Inject]
    public IGameService _service { get; set; }

    // Liste pour l'affichage
    public List<Game> GameList { get; set; } = new();

    // Methode executé au chargement du composant
    protected override void OnInitialized()
    {
        // Recuperation des informations depuis le service
        GameList = _service.GetGames();
    }

    // Permet de naviguer entre les pages
    [Inject]
    public NavigationManager _nav { get; set; }

    // methode pour naviguer vers la page d'ajout
    public void NavigateToAdd()
    {
        _nav.NavigateTo("/add-game");
    }

    // methode pour naviguer vers la page de mise à jour avec un paramètre
    public void NavigateToUpdate(int id)
    {
        _nav.NavigateTo($"/update-game/{id}");
    }
}